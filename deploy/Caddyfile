# Caddy reverse proxy for h01.mmsim.com
#
# Sits in front of the Hermes dashboard (Python) and the login portal (Node).
# All requests hit this proxy first. Anything that is not an auth-related path
# must present a valid session cookie (issued by the Node login service) before
# it is forwarded to the dashboard.
#
# Expected sibling services on Zeabur:
#   - hermes-login      (this Node repo, listening on port 4173)
#   - hermes-dashboard  (existing Python/uvicorn app; adjust the upstream
#                        hostname and port below to match your service)
#
# Replace the upstream hostnames if your Zeabur service names differ.

{
	admin off
	auto_https off
}

:80 {
	encode zstd gzip

	# --- Public: login page, its assets, and the POST endpoint ---
	@login_paths path /login /login/* /logout /auth-check /favicon.ico /assets/*
	handle @login_paths {
		reverse_proxy hermes-login:4173
	}

	# --- Protected: everything else requires a valid session cookie ---
	handle {
		forward_auth hermes-login:4173 {
			uri /auth-check
			copy_headers Cookie
		}
		reverse_proxy hermes-dashboard:5000
	}

	# Turn 401 responses (from forward_auth or upstream) into a redirect to /login.
	handle_errors {
		@unauth expression `{err.status_code} == 401`
		redir @unauth /login 302
	}
}
